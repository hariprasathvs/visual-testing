{
  "name": "visual-testing-app",
  "version": "1.0.0",
  "main": "index.js",
  "scripts": {
    "start": "expo start",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "test-ui": "npx playwright test --ui",
    "test-chrome": "npx playwright test --project=chromium --headed",
    "test-codegen": "npx playwright codegen",
    "test-visual": "npx playwright test --grep @visual",
    "show-report": "npx playwright show-report",
    "build": "expo build",
    "eject": "expo eject"
  },
  "keywords": [
    "react-native",
    "expo",
    "playwright",
    "visual-testing"
  ],
  "author": "Hari Prasath",
  "license": "ISC",
  "description": "React Native app with Playwright visual testing",
  "dependencies": {
    "@expo/webpack-config": "^19.0.1",
    "expo": "~50.0.0",
    "expo-status-bar": "~1.11.1",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "react-native": "0.73.6",
    "react-native-web": "~0.19.10"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.1",
    "@playwright/test": "^1.50.1",
    "@types/node": "^22.13.1",
    "@types/react": "~18.2.45",
    "@types/react-native": "~0.73.0",
    "dotenv": "^16.4.7",
    "http-server": "^14.1.1",
    "lighthouse": "^12.3.0",
    "path": "^0.12.7",
    "playwright": "^1.50.1",
    "playwright-lighthouse": "^4.0.0",
    "typescript": "^5.1.3"
  }
